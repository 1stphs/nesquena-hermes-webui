# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Backup and temporary files
*.bak
*.swp
*.swo

# Archive directory (pre-git backups, kept on disk but not tracked)
archive/
tmp/

# Local environment and secrets (but keep the example templates)
.env
.env.*
!.env.example
!.env.docker.example
.claude/
CLAUDE.md
AGENTS.md
.cursorrules
.windsurfrules
.aider*
copilot-instructions.md

# Generated screenshots and transient artifacts
screenshot-*.png
full-UI.png
hermes-agent-src/build/

# Local test suite; keep on disk but do not upload to git.
tests/

# Version file written by Docker/CI build — generated, never committed
api/_version.py

# Routes refactor contracts are repo documentation, even when a developer has
# a global Markdown ignore rule.
!api/routes-refactor-step1.md
!api/routes-refactor-step2.md
!api/routes-refactor-followups.md
!api/routes-refactor-report.md
!api/routes-handlers-contract.md

# OS files
.DS_Store
Thumbs.db

# docs/ — 项目文档目录，全部纳入版本管理，禁止添加忽略规则
# 含 Markdown、HTML 渲染页及 docs/other/ 子目录；新增文档直接 git add 后提交

# Local-only PR review harness: rendering drivers, sample bank, fixtures.
# Used by Claude during deep reviews; never shared in the repo.
.local-review/
graphify-out/
.graphify_cached.json
.graphify_uncached.txt
