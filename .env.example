# Hermes Web UI — 本地机器配置模板
# 复制为 .env 并填入你的值。
# 若存在 .env，start.sh 会自动加载。
# 所有值均为可选；留空时由自动发现逻辑补全。

# hermes-agent 源码目录（包含 run_agent.py 的仓库路径）
# HERMES_WEBUI_AGENT_DIR=/path/to/hermes-agent

# 使用的 Python 可执行文件（默认优先使用 agent venv）
# HERMES_WEBUI_PYTHON=/path/to/python

# 监听地址（默认 127.0.0.1，仅本机回环，安全默认值）
# HERMES_WEBUI_HOST=127.0.0.1

# 监听端口（默认 8787）
# HERMES_WEBUI_PORT=8787

# 会话、工作区及其他状态的存储目录（默认 ~/.hermes/webui-mvp）
# HERMES_WEBUI_STATE_DIR=~/.hermes/webui

# 首次启动时展示的默认工作区目录
# HERMES_WEBUI_DEFAULT_WORKSPACE=~/workspace

# 所有 Hermes 状态的根目录（设置后会影响上方相关路径）
# HERMES_HOME=~/.hermes

# Hermes config.yaml 路径（工具集与模型配置）
# HERMES_CONFIG_PATH=~/.hermes/config.yaml

# UI 中助手的显示名称（默认 Hermes）
# HERMES_WEBUI_BOT_NAME=Hermes

# 内存压力限流：登录 / 新建会话 / 发起聊天等高成本入口（默认关闭）。
# 开启后，当宿主机内存使用率超过 75% 时将拒绝上述请求。
# HERMES_WEBUI_MEMORY_PRESSURE_LIMIT=1

# Hermes WebUI 用户技能双写所用的服务端 NoCoBase API。
# Authorization 仅放在后端运行时环境，切勿暴露到前端构建变量。
# NOCOBASE_API_BASE_URL=https://www.foxuai.com/api
# NOCOBASE_AUTHORIZATION=Bearer <nocobase-token>
# NOCOBASE_HOSTNAME=www.foxuai.com
# NOCOBASE_AUTHENTICATOR=basic
